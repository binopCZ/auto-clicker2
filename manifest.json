{
  "manifest_version": 3,
  "name": "Auto Clicker",
  "description": "Automatic clicker with single and multi-target modes, configurable shortcuts and Cookie Clicker support.",
  "version": "2.0.0",
  "author": "Binop",

  "action": {
    "default_title": "Auto Clicker",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],

  "host_permissions": [
    "*://orteil.dashnet.org/*"
  ]
}
